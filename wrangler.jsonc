{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ongato-serverless",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-16",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"d1_databases": [
		{
		"binding": "DB",
		"database_name": "ongato-db",
		"database_id": "bc0d876f-c6dd-4b8d-8bd2-aa15b3a65341"
		}
	]
}